---
import { SUBJECT_COLORS } from '../lib/types';
import type { Topic } from '../lib/types';

const { topic, compact = false } = Astro.props as { topic: Topic; compact?: boolean };

const base = import.meta.env.BASE_URL;
const color = SUBJECT_COLORS[topic.subject] || '#6b7280';
const typeAbbr: Record<string, string> = {
  CONCEPTUAL: 'C', PROCEDURAL: 'P', REPRESENTATIONAL: 'R', LANGUAGE: 'L', META: 'M',
};
---

<a href={`${base}topics/${topic.id}`} class="block group">
  <div class="bg-white rounded-lg border border-gray-200 p-4 hover:border-marble-300 hover:shadow-md transition-all h-full">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-semibold text-gray-900 group-hover:text-marble-600 transition-colors line-clamp-2">
        {topic.name}
      </h3>
      <div class="flex items-center gap-1 shrink-0">
        <span class={`topic-type-badge topic-type-${topic.type}`}>{typeAbbr[topic.type] || topic.type[0]}</span>
      </div>
    </div>

    {!compact && (
      <p class="text-sm text-gray-600 line-clamp-2 mb-3">{topic.description}</p>
    )}

    <div class="flex items-center gap-2 text-xs text-gray-500">
      <span class="px-1.5 py-0.5 rounded font-medium text-white" style={`background-color: ${color}`}>
        {topic.subject}
      </span>
      <span>{topic.domain}</span>
      <span class="ml-auto">Ages {topic.ageRangeStart}&mdash;{topic.ageRangeEnd}</span>
    </div>
  </div>
</a>
